# =============================================================
# Outbrew Frontend - Production Environment Variables
# Set these in Vercel Dashboard > Project Settings > Environment Variables
# =============================================================

# Backend Host (REQUIRED)
# The base URL of your Hetzner VPS backend (no /api/v1 suffix).
# Used by next.config.js rewrites to proxy /api/* requests.
# Example: https://api.outbrew.metaminds.store
NEXT_PUBLIC_BACKEND_HOST=https://YOUR_HETZNER_IP_OR_DOMAIN

# Backend API URL (REQUIRED)
# Full API URL used by frontend axios client for direct API calls.
# Example: https://api.outbrew.metaminds.store/api/v1
NEXT_PUBLIC_API_URL=https://YOUR_HETZNER_IP_OR_DOMAIN/api/v1

# App URL (for OpenGraph metadata, sitemap, etc.)
NEXT_PUBLIC_APP_URL=https://metaminds.store
